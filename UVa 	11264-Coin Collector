#define f first
#define s second
#define ll long long



int main(){
    int t; cin >> t;
    while (t--){
        int n; cin >> n; 
        vector<ll> a(n);
        for (int i = 0; i < n; i++){
            cin >> a[i];
        }
        ll sum = 0;
        int ans = 0;
        for (int i = 0; i < n-1; i++){
            if (sum + a[i] < a[i+1]){
                sum += a[i];
                ans++;
            }
        }
        cout << ans+1 << endl;

    }
    return 0;
}
